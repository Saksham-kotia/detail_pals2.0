# DETAIL PALS V2 — Environment Variables
# =========================================
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored — never commit real credentials.
#
# Find these values in your Supabase project:
#   Dashboard → Settings → API → Project URL + anon/public key

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# The SERVICE ROLE key is NEVER placed here.
# It lives in Supabase Edge Function secrets only.
# Dashboard → Settings → API → service_role key
# Then: supabase secrets set SUPABASE_SERVICE_ROLE_KEY=<value>
